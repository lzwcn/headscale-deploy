HS_ROOT=./runtime/instance
HEADSCALE_IMAGE=ghcr.io/juanfont/headscale
HEADSCALE_TAG=0.28.0
HS_CONTAINER=headscale
SERVER_URL="https://<your-headscale-domain>"
PORT=8080
# Keep 0.0.0.0 for the default IPv4 listener. Use :: if you want an IPv6 / dual-stack friendly host listener.
LISTEN_ADDR=0.0.0.0
FIRST_USERNAME=admin
BASE_DOMAIN=headscale.internal
# host is the default because it avoids Docker port publishing for Embedded DERP/STUN and is the safest general default.
DOCKER_MODE=host
# Used only when DOCKER_MODE=network.
HS_DOCKER_NETWORK=
DERP_MODE=disabled
# The DERP_* settings below are used only when DERP_MODE is private or public.
DERP_REGION_ID=999
DERP_REGION_CODE=headscale
DERP_REGION_NAME="Headscale Embedded DERP"
# :3478 is the recommended default. Use [::]:3478 when you need to spell out an IPv6 wildcard STUN listener explicitly.
DERP_STUN_LISTEN_ADDR=:3478
DERP_IPV4=
DERP_IPV6=
DERP_INCLUDE_DEFAULTS=true
DERP_AUTO_ADD_EMBEDDED_REGION=true
DNS_GLOBAL_NAMESERVERS=1.1.1.1,1.0.0.1,2606:4700:4700::1111,2606:4700:4700::1001
